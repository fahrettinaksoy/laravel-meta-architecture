{
  "name": "laravel-meta-architecture",
  "domain": "laravel-meta-architecture.loc",
  "webserver": "nginx",
  "document_root": "public",
  "php": {
    "version": "8.4",
    "extensions": [
      "mbstring",
      "tokenizer",
      "xml",
      "ctype",
      "openssl",
      "pdo",
      "fileinfo",
      "curl",
      "pdo_mysql",
      "pdo_pgsql",
      "pdo_sqlite",
      "redis",
      "zip",
      "bcmath",
      "dom",
      "pcntl",
      "xdebug"
    ]
  }
}
